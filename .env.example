# IA — choisis ton provider : "gemini" ou "claude"
AI_PROVIDER=gemini

# Google Gemini API (recommandé)
# Obtenir sur: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Claude API (Anthropic — optionnel)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Meta (Instagram + Facebook)
# Obtenir sur: https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# Hébergement images (requis pour Meta API)
# Compte gratuit sur: https://imgbb.com/
IMGBB_API_KEY=

# Serveur
SERVER_URL=http://localhost:8000
PORT=8000
